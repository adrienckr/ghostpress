"""{{ spec.name }} MCP server -- generated by ghostpress."""
from __future__ import annotations

import asyncio
from typing import Any

import httpx
from mcp import types as mcp_types
from mcp.server import Server
from mcp.server.stdio import stdio_server


server = Server("{{ spec.name }}")


@server.list_tools()
async def _list_tools() -> list[mcp_types.Tool]:
    return [
        {%- for cmd in spec.commands %}
        mcp_types.Tool(
            name="{{ cmd.name | replace('-', '_') }}",
            description={{ cmd.description | tojson }},
            inputSchema={
                "type": "object",
                "properties": {
                    {%- for p in cmd.path_params %}
                    "{{ p }}": {"type": "string"},
                    {%- endfor %}
                    {%- for q in cmd.query_params %}
                    "{{ q }}": {"type": "string"},
                    {%- endfor %}
                    {%- for f in cmd.body_fields %}
                    "{{ f }}": {"type": "string"},
                    {%- endfor %}
                    {%- if cmd.body_is_raw %}
                    "body": {"type": "string"},
                    {%- endif %}
                },
                "required": [{% for p in cmd.path_params %}"{{ p }}"{% if not loop.last %}, {% endif %}{% endfor %}],
            },
        ),
        {%- endfor %}
    ]


@server.call_tool()
async def _call_tool(name: str, arguments: dict[str, Any]) -> list[mcp_types.TextContent]:
    args = arguments or {}
    {%- for cmd in spec.commands %}
    if name == "{{ cmd.name | replace('-', '_') }}":
        url = "{{ cmd.url_template }}"
        {%- for p in cmd.path_params %}
        url = url.replace("{{ '{' ~ p ~ '}' }}", str(args["{{ p }}"]))
        {%- endfor %}
        params = {
            {%- for q in cmd.query_params %}
            "{{ q }}": args.get("{{ q }}"),
            {%- endfor %}
        }
        params = {k: v for k, v in params.items() if v is not None}
        headers = {{ cmd.headers | tojson }}
        kwargs: dict[str, Any] = {"params": params, "headers": headers}
        {%- if cmd.body_fields %}
        body = {k: args.get(k) for k in [{% for f in cmd.body_fields %}"{{ f }}"{% if not loop.last %}, {% endif %}{% endfor %}] if args.get(k) is not None}
        kwargs["json"] = body
        {%- elif cmd.body_is_raw %}
        kwargs["content"] = args.get("body")
        {%- endif %}
        async with httpx.AsyncClient(timeout=30.0, follow_redirects=True) as client:
            response = await client.request("{{ cmd.method }}", url, **kwargs)
        return [mcp_types.TextContent(type="text", text=response.text)]
    {%- endfor %}
    raise ValueError(f"Unknown tool: {name}")


async def main() -> None:
    async with stdio_server() as (read_stream, write_stream):
        await server.run(read_stream, write_stream, server.create_initialization_options())


if __name__ == "__main__":
    asyncio.run(main())
